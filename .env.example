# ── Ports ────────────────────────────────────────────────────────────────────
# External port the web UI is served on (default: 8000)
PORT=8000

# ── AI (optional) ─────────────────────────────────────────────────────────────
# Leave empty to use a local Ollama instance (auto-detected)
ANTHROPIC_API_KEY=

# ── Internal service URLs (used for non-Docker / native installs) ─────────────
# Docker Compose overrides these automatically — no need to change them here
BOT_PORT=3001
BOT_API_URL=http://localhost:3001
PYTHON_API_URL=http://localhost:8000

# ── Data directory (non-Docker only) ─────────────────────────────────────────
# Docker Compose pins this to /app/data automatically
DATA_DIR=./data
